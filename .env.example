# Local-only. For production use `wrangler secret put <NAME>` instead.
#
# Wrangler dev reads `.dev.vars` (also gitignored). Copy this template to
# `.dev.vars` and fill in real values for local testing with `wrangler dev`.

# Gemini Live API — production interview path (audio in/out + Korean TTS)
GEMINI_API_KEY=

# SpatialReal AvatarKit — 3D 면접관 아바타
# Get from https://studio.spatialreal.ai → Dashboard
SPATIALREAL_APP_ID=
SPATIALREAL_API_KEY=
SPATIALREAL_AVATAR_ID=
# Phase B (current): manually-rotated session token (max 1h validity).
# Re-issue from Studio every ~50 minutes during demos.
# Phase A (TBD): replace with vendor mint endpoint when API spec arrives.
SPATIALREAL_SESSION_TOKEN=

# Legacy / unused (4월 design, 보존만)
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
